# Rename to .env and fill with your real secrets. Never commit real secrets to git.
PATREON_CLIENT_ID=your_client_id_here
PATREON_CLIENT_SECRET=your_client_secret_here
PATREON_REDIRECT_URI=http://localhost:3000/auth/patreon/callback
PATREON_ALLOWED_TIER_NAME=Mel Apprentice
# Optional: prefer PATREON_ALLOWED_TIER_ID for an exact tier match that does not depend on the tier title.
PATREON_ALLOWED_TIER_ID=
SESSION_SECRET=change-me-to-a-random-value
FRONTEND_URL=http://localhost:3000
PORT=3000
